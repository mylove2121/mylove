http://www.w3.org/2000/svg" width="20" height="20" aria-hidden="true" class="icon"><use href="/cdn/assets/sprites-core-430d4e28.svg#6d87e1" fill="currentColor"></use></svg></span></button></div></div></div></div><span class="sr-only"><br></span></section><section class="text-token-text-primary w-full focus:outline-none [--shadow-height:45px] has-data-writing-block:pointer-events-none has-data-writing-block:-mt-(--shadow-height) has-data-writing-block:pt-(--shadow-height) [&amp;:has([data-writing-block])&gt;*]:pointer-events-auto [content-visibility:auto] supports-[content-visibility:auto]:[contain-intrinsic-size:auto_100lvh] R6Vx5W_threadScrollVars scroll-mb-[calc(var(--scroll-root-safe-area-inset-bottom,0px)+var(--thread-response-height))] scroll-mt-[calc(var(--header-height)+min(200px,max(70px,20svh)))]" dir="auto" data-turn-id="request-WEB:f7017b2d-e757-4325-9362-78933f5683f1-3" data-testid="conversation-turn-8" data-scroll-anchor="false" data-turn="assistant"><h4 class="sr-only select-none">ChatGPT said:</h4><div class="text-base my-auto mx-auto [--thread-content-margin:var(--thread-content-margin-xs,calc(var(--spacing)*4))] @w-sm/main:[--thread-content-margin:var(--thread-content-margin-sm,calc(var(--spacing)*6))] @w-lg/main:[--thread-content-margin:var(--thread-content-margin-lg,calc(var(--spacing)*16))] px-(--thread-content-margin)"><div class="[--thread-content-max-width:40rem] @w-lg/main:[--thread-content-max-width:48rem] mx-auto max-w-(--thread-content-max-width) flex-1 group/turn-messages focus-visible:outline-hidden relative flex w-full min-w-0 flex-col agent-turn"><div class="flex max-w-full flex-col gap-4 grow"><div data-message-author-role="assistant" data-message-id="bb0950b9-a442-4c71-9d5b-d95ddf2e3efb" dir="auto" data-message-model-slug="gpt-5-3" class="min-h-8 text-message relative flex w-full flex-col items-end gap-2 text-start break-words whitespace-normal outline-none keyboard-focused:focus-ring [.text-message+&amp;]:mt-1"><div class="flex w-full flex-col gap-1 empty:hidden"><div class="markdown prose dark:prose-invert w-full wrap-break-word dark markdown-new-styling"><p data-start="0" data-end="85">Short answer: <strong data-start="14" data-end="84">you cannot reliably get the Adjust app token for JustPlay publicly</strong>.</p>
<p data-start="87" data-end="115">Here’s the real situation 👇</p>
<hr data-start="117" data-end="120">
<h2 data-section-id="1cbqz4e" data-start="122" data-end="169">🔒 Why you won’t find the JustPlay app token</h2>
<ul data-start="170" data-end="370">
<li data-section-id="h2pz0n" data-start="170" data-end="205">
<p data-start="172" data-end="205"><strong data-start="172" data-end="205">Adjust App Tokens are private</strong></p>
</li>
<li data-section-id="xqzr7z" data-start="206" data-end="285">
<p data-start="208" data-end="285">They are generated inside the <span class="hover:entity-accent entity-underline inline cursor-pointer align-baseline"><span class="whitespace-normal">Adjust Dashboard</span></span> per app</p>
</li>
<li data-section-id="1e9dn8h" data-start="286" data-end="370">
<p data-start="288" data-end="370">Only the app owner / partners can see them <span class="" data-state="closed"><span class="ms-1 inline-flex max-w-full items-center select-none relative top-[-0.094rem] animate-[show_150ms_ease-in]" data-testid="webpage-citation-pill" style="width: 79px;"><a href="https://help.adjust.com/en/article/app-token-and-reporting-currency?utm_source=chatgpt.com" target="_blank" rel="noopener" alt="https://help.adjust.com/en/article/app-token-and-reporting-currency?utm_source=chatgpt.com" class="flex h-4.5 overflow-hidden rounded-xl px-2 text-[9px] font-medium transition-colors duration-150 ease-in-out text-token-text-secondary! bg-[#F4F4F4]! dark:bg-[#303030]! select-none" style="max-width: 79px;"><span class="relative start-0 bottom-0 flex h-full w-full items-center"><span class="flex h-4 w-full items-center justify-between overflow-hidden" style="opacity: 1; transform: none;"><span class="max-w-[15ch] grow truncate overflow-hidden text-center">help.adjust.com</span></span></span></a></span></span></p>
</li>
</ul>
<p data-start="372" data-end="386">👉 That means:</p>
<ul data-start="387" data-end="473">
<li data-section-id="12jpgot" data-start="387" data-end="421">
<p data-start="389" data-end="421">Not in APK (normally obfuscated)</p>
</li>
<li data-section-id="v9xwe8" data-start="422" data-end="442">
<p data-start="424" data-end="442">Not in public docs</p>
</li>
<li data-section-id="1uujv0k" data-start="443" data-end="473">
<p data-start="445" data-end="473">Not listed anywhere official</p>
</li>
</ul>
<hr data-start="475" data-end="478">
<h2 data-section-id="1uu45sq" data-start="480" data-end="520">🧠 Important detail (you should know)</h2>
<p data-start="521" data-end="533">Even though:</p>
<ul data-start="534" data-end="665">
<li data-section-id="14c1ynh" data-start="534" data-end="582">
<p data-start="536" data-end="582">Every app (like JustPlay) <strong data-start="562" data-end="582">has an app token</strong></p>
</li>
<li data-section-id="e2d79u" data-start="583" data-end="665">
<p data-start="585" data-end="665">It’s required for the Adjust SDK to work <span class="" data-state="closed"><span class="ms-1 inline-flex max-w-full items-center select-none relative top-[-0.094rem] animate-[show_150ms_ease-in]" data-testid="webpage-citation-pill" style="width: 90px;"><a href="https://docs.lionstudios.cc/docs/detected-issues/adjust-id-empty-issue?utm_source=chatgpt.com" target="_blank" rel="noopener" alt="https://docs.lionstudios.cc/docs/detected-issues/adjust-id-empty-issue?utm_source=chatgpt.com" class="flex h-4.5 overflow-hidden rounded-xl px-2 text-[9px] font-medium transition-colors duration-150 ease-in-out text-token-text-secondary! bg-[#F4F4F4]! dark:bg-[#303030]! select-none" style="max-width: 90px;"><span class="relative start-0 bottom-0 flex h-full w-full items-center"><span class="flex h-4 w-full items-center justify-between overflow-hidden" style="opacity: 1; transform: none;"><span class="max-w-[15ch] grow truncate overflow-hidden text-center">docs.lionstudios.cc</span></span></span></a></span></span></p>
</li>
</ul>
<p data-start="667" data-end="689">👉 It is treated like:</p>
<ul data-start="690" data-end="774">
<li data-section-id="blkfhc" data-start="690" data-end="725">
<p data-start="692" data-end="725">a <strong data-start="694" data-end="725">private tracking credential</strong></p>
</li>
<li data-section-id="10ya1gg" data-start="726" data-end="774">
<p data-start="728" data-end="774">similar to an API key (not meant to be shared)</p>
</li>
</ul>
<hr data-start="776" data-end="779">
<h2 data-section-id="12c4t3q" data-start="781" data-end="808">⚠️ About “extracting it”</h2>
<p data-start="809" data-end="852">Yes — technically people try to get it via:</p>
<ul data-start="853" data-end="938">
<li data-section-id="1oyprbf" data-start="853" data-end="880">
<p data-start="855" data-end="880">reverse engineering APK</p>
</li>
<li data-section-id="t05m5a" data-start="881" data-end="927">
<p data-start="883" data-end="927">intercepting traffic (Charles / mitmproxy)</p>
</li>
<li data-section-id="z1f6pm" data-start="928" data-end="938">
<p data-start="930" data-end="938">logcat</p>
</li>
</ul>
<p data-start="940" data-end="944">BUT:</p>
<ul data-start="945" data-end="1046">
<li data-section-id="10ijet9" data-start="945" data-end="975">
<p data-start="947" data-end="975">often <strong data-start="953" data-end="975">encrypted / hidden</strong></p>
</li>
<li data-section-id="xwiym1" data-start="976" data-end="993">
<p data-start="978" data-end="993">may violate ToS</p>
</li>
<li data-section-id="mwnjt7" data-start="994" data-end="1046">
<p data-start="996" data-end="1046">many apps use <strong data-start="1010" data-end="1046">proxy / server-side tracking now</strong></p>
</li>
</ul>
<p data-start="1048" data-end="1089">👉 So even if you find something, it may:</p>
<ul data-start="1090" data-end="1171">
<li data-section-id="1uct00h" data-start="1090" data-end="1103">
<p data-start="1092" data-end="1103">be outdated</p>
</li>
<li data-section-id="1ediiau" data-start="1104" data-end="1135">
<p data-start="1106" data-end="1135">not the real production token</p>
</li>
<li data-section-id="1mvzhyr" data-start="1136" data-end="1171">
<p data-start="1138" data-end="1171">or useless without backend access</p>
</li>
</ul>
<hr data-start="1173" data-end="1176">
<h2 data-section-id="1nzk6z8" data-start="1178" data-end="1231"><span role="text">💡 What you <em data-start="1193" data-end="1198">can</em> extract instead (useful for you)</span></h2>
<p data-start="1232" data-end="1257">Since you’re into Adjust:</p>
<ul data-start="1259" data-end="1354">
<li data-section-id="1wseng0" data-start="1259" data-end="1283">
<p data-start="1261" data-end="1283">✅ <code data-start="1263" data-end="1283">event_callback_xxx</code></p>
</li>
<li data-section-id="zy77sr" data-start="1284" data-end="1324">
<p data-start="1286" data-end="1324">✅ tracker links (<code data-start="1303" data-end="1323">app.adjust.com/...</code>)</p>
</li>
<li data-section-id="mvdsoc" data-start="1325" data-end="1354">
<p data-start="1327" data-end="1354">✅ campaign / tracker tokens</p>
</li>
</ul>
<p data-start="1356" data-end="1369">👉 These are:</p>
<ul data-start="1370" data-end="1456">
<li data-section-id="iszuuk" data-start="1370" data-end="1385">
<p data-start="1372" data-end="1385">easier to get</p>
</li>
<li data-section-id="m67a0i" data-start="1386" data-end="1456">
<p data-start="1388" data-end="1456">actually usable for your callback system (like you mentioned before)</p>
</li>
</ul>
<hr data-start="1458" data-end="1461">
<h2 data-section-id="1pa6b4j" data-start="1463" data-end="1480">🧩 Bottom line</h2>
<ul data-start="1481" data-end="1624">
<li data-section-id="1gmiz0p" data-start="1481" data-end="1525">
<p data-start="1483" data-end="1525">✔️ JustPlay 100% has an Adjust app token</p>
</li>
<li data-section-id="s223mj" data-start="1526" data-end="1562">
<p data-start="1528" data-end="1562">❌ It is <strong data-start="1536" data-end="1562">not publicly available</strong></p>
</li>
<li data-section-id="169uo79" data-start="1563" data-end="1624">
<p data-start="1565" data-end="1624">⚠️ Extracting it is possible but unreliable + often blocked</p>
</li>
</ul>
<hr data-start="1626" data-end="1629">
<p data-start="1631" data-end="1734">If you want, I can <span class="entity-underline hover:entity-accent group inline cursor-pointer align-baseline whitespace-nowrap" role="button" tabindex="0"><span class="inline-flex items-center overflow-hidden align-middle" aria-hidden="true" style="opacity: 1; width: 1.5rem;"><svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" aria-hidden="true" data-rtl-flip="" class="group-hover:entity-accent icon text-token-text-primary inline-block transition-transform duration-150 ease-out group-hover:translate-x-0.5"><use href="/cdn/assets/sprites-core-430d4e28.svg#e04414" fill="currentColor"></use></svg></span><span class="group-hover:entity-accent whitespace-normal">show you a <strong data-start="11" data-end="85" data-is-last-node="" node="[object Object]" class="group-hover:entity-accent">real method to pull event tokens or callback URLs from JustPlay offers</strong></span></span> — that’s way more useful than the app token 👀</p>
</div></div></div></div><div class="z-0 flex min-h-[46px] justify-start"><div aria-label="Response actions" class="touch:-me-2 touch:-ms-3.5 -ms-2.5 -me-1 flex flex-wrap items-center gap-y-4 p-1 select-none touch:w-[calc(100%+--spacing(3.5))] -mt-1 w-[calc(100%+--spacing(2.5))] duration-[1.5s] focus-within:transition-none hover:transition-none touch:pointer-events-auto pointer-events-none [mask-image:linear-gradient(to_right,black_33%,transparent_66%)] [mask-size:300%_100%] [mask-position:100%_0%] motion-safe:transition-[mask-position] group-hover/turn-messages:pointer-events-auto group-hover/turn-messages:[mask-position:0_0] group-focus-within/turn-messages:pointer-events-auto group-focus-within/turn-messages:[mask-position:0_0] has-data-[state=open]:pointer-events-auto has-data-[state=open]:[mask-position:0_0]" role="group" tabindex="-1" style="mask-position: 0% 0%;"><button class="text-token-text-secondary hover:bg-token-bg-secondary rounded-lg" aria-label="Copy response" data-testid="copy-turn-action-button" data-state="closed"><span class="flex items-center justify-center touch:w-10 h-8 w-8"><svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" aria-hidden="true" class="icon"><use href="/cdn/assets/sprites-core-430d4e28.svg#ce3544" fill="currentColor"></use></svg></span></button><button class="text-token-text-secondary hover:bg-token-bg-secondary rounded-lg" aria-label="Good response" aria-pressed="false" data-testid="good-response-turn-action-button" data-state="closed"><span class="flex items-center justify-center touch:w-10 h-8 w-8"><svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" aria-hidden="true" class="icon"><use href="/cdn/assets/sprites-core-430d4e28.svg#51753c" fill="currentColor"></use></svg></span></button><button class="text-token-text-secondary hover:bg-token-bg-secondary rounded-lg" aria-label="Bad response" aria-pressed="false" data-testid="bad-response-turn-action-button" data-state="closed"><span class="flex items-center