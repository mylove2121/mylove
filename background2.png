-chat-width,70%)"><div class="[overflow-wrap:anywhere] whitespace-pre-wrap">&lt;!DOCTYPE html&gt;
&lt;html lang="de"&gt;

&lt;head&gt;
    &lt;meta charset="UTF-8"&gt;
    &lt;meta name="viewport" content="width=device-width, initial-scale=1.0"&gt;
    &lt;title&gt;REFHUNTER&lt;/title&gt;
    &lt;link rel="icon" type="image/png" href="REFHUNTER.PNG"&gt;

    &lt;style&gt;
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: ui-sans-serif, system-ui, Arial;
            color: #fff;

            background:
                linear-gradient(rgba(0,0,0,0.75), rgba(0,0,0,0.9)),
                url("backround.png");

            background-size: cover;
            background-position: center;
            background-attachment: fixed;
        }

        .hero-banner {
            position: relative;
            width: 100%;
            height: 420px;
            overflow: hidden;
            border-bottom: 1px solid rgba(180,255,120,.15);
        }

        .hero-banner img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            filter: brightness(0.5);
        }

        /* 🔥 NEUER CLEAN LOOK */
        .hero-overlay {
            position: absolute;
            top: 60px;
            left: 80px;

            background: rgba(0,0,0,0.25);
            backdrop-filter: blur(6px);

            padding: 20px 30px;
            border-radius: 12px;

            border: 1px solid rgba(140,255,0,0.2);
        }

        /* ✨ SHARP + ANIMATED TEXT */
        .hero-overlay h1 {
            font-size: 72px;
            font-weight: 800;
            letter-spacing: 2px;

            font-family: 'Arial Black', sans-serif;

            background: linear-gradient(90deg, #b6ff5c, #6aff00, #b6ff5c);
            background-size: 200%;

            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;

            animation: shine 6s linear infinite;

            text-shadow:
                0 0 10px rgba(140,255,0,0.7),
                0 0 20px rgba(100,255,0,0.4),
                0 0 40px rgba(80,255,0,0.2);

            -webkit-font-smoothing: antialiased;
            text-rendering: optimizeLegibility;
        }

        @keyframes shine {
            0% { background-position: 0%; }
            100% { background-position: 200%; }
        }

        .hero-overlay h1:hover {
            text-shadow:
                0 0 20px rgba(140,255,0,1),
                0 0 40px rgba(100,255,0,0.8),
                0 0 80px rgba(80,255,0,0.6);
        }

        .hero-overlay p {
            margin-top: 10px;
            color: #ccc;
            font-size: 18px;
        }

        .container {
            max-width: 1400px;
            margin: auto;
            padding: 40px 20px;
        }

        .search {
            margin: 30px 0;
            display: flex;
            gap: 10px;
        }

        .search input {
            flex: 1;
            padding: 14px;
            border-radius: 10px;
            background: rgba(22, 32, 20, .85);
            border: 1px solid rgba(180, 255, 120, .15);
            color: #fff;
        }

        .cards {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
            gap: 20px;
        }

        .card {
            background: rgba(22, 32, 20, .85);
            border: 1px solid rgba(180, 255, 120, .1);
            border-radius: 16px;
            padding: 20px;
            text-align: center;
            transition: .2s;
            backdrop-filter: blur(6px);
        }

        .card:hover {
            transform: translateY(-5px);
            border-color: rgba(180, 255, 120, .4);
        }

        .logo {
            width: 84px;
            height: 84px;
            border-radius: 10px;
            margin-bottom: 10px;
        }

        .btn {
            display: inline-block;
            margin-top: 10px;
            background: linear-gradient(180deg, #c8f07a, #9ec94e);
            color: #111;
            padding: 10px 16px;
            border-radius: 10px;
            text-decoration: none;
            font-weight: bold;
        }

        .footer {
            text-align: center;
            color: #777;
            padding: 40px 0;
        }
    &lt;/style&gt;
&lt;/head&gt;

&lt;body&gt;

