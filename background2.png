rgin:var(--thread-content-margin-sm,calc(var(--spacing)*6))] @w-lg/main:[--thread-content-margin:var(--thread-content-margin-lg,calc(var(--spacing)*16))] px-(--thread-content-margin)"><div class="[--thread-content-max-width:40rem] @w-lg/main:[--thread-content-max-width:48rem] mx-auto max-w-(--thread-content-max-width) flex-1 group/turn-messages focus-visible:outline-hidden relative flex w-full min-w-0 flex-col"><div class="flex max-w-full flex-col gap-4 grow"><div data-message-author-role="user" data-message-id="d0bc0b30-131d-4df4-b1af-db6674c837be" dir="auto" class="min-h-8 text-message relative flex w-full flex-col items-end gap-2 text-start break-words whitespace-normal outline-none keyboard-focused:focus-ring [.text-message+&amp;]:mt-1"><div class="flex w-full flex-col gap-1 empty:hidden items-end rtl:items-start"><div class="user-message-bubble-color corner-superellipse/0.98 relative min-w-0 rounded-[22px] px-4 py-2.5 leading-6 max-w-(--user-chat-width,70%)"><div class="[overflow-wrap:anywhere] whitespace-pre-wrap">&lt;!DOCTYPE html&gt;
&lt;html lang="de"&gt;

&lt;head&gt;
&lt;meta charset="UTF-8"&gt;
&lt;meta name="viewport" content="width=device-width, initial-scale=1.0"&gt;
&lt;title&gt;REFHUNTER&lt;/title&gt;

&lt;style&gt;
* {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
}

body {
    font-family: ui-sans-serif, system-ui, Arial;
    color: #fff;

    background:
        linear-gradient(rgba(0,0,0,0.75), rgba(0,0,0,0.9)),
        url("backround.png");

    background-size: cover;
    background-position: center;
    background-repeat: no-repeat;
}

/* ✅ PERFECT BALANCE */
.hero-banner {
    width: 100%;
    height: 320px; /* 👈 balanced height */
    display: flex;
    justify-content: center;
    align-items: center;
    background: rgba(0,0,0,0.6);
    border-bottom: 1px solid rgba(180,255,120,.15);
}

.hero-banner img {
    width: 150%;
    height: 100%;
    object-fit: contain; /* 👈 FULL IMAGE visible */
    object-position: center;
}

/* Overlay */
.hero-overlay {
    position: absolute;
    top: 40px;
    left: 60px;

    background: rgba(0,0,0,0.35);
    backdrop-filter: blur(6px);

    padding: 16px 26px;
    border-radius: 12px;

    border: 1px solid rgba(140,255,0,0.2);
}

.hero-overlay h1 {
    font-size: 56px;
    font-weight: 800;

    background: linear-gradient(90deg, #b6ff5c, #6aff00, #b6ff5c);
    background-size: 200%;

    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;

    animation: shine 6s linear infinite;

    text-shadow:
        0 0 10px rgba(140,255,0,0.7),
        0 0 20px rgba(100,255,0,0.4);
}

@keyframes shine {
    0% { background-position: 0%; }
    100% { background-position: 200%; }
}

.hero-overlay p {
    margin-top: 8px;
    color: #ccc;
    font-size: 16px;
}

.container {
    max-width: 1400px;
    margin: auto;
    padding: 40px 20px;
}

.search {
    margin: 30px 0;
}

.search input {
    width: 100%;
    padding: 14px;
    border-radius: 10px;
    background: rgba(22, 32, 20, .85);
    border: 1px solid rgba(180, 255, 120, .15);
    color: #fff;
}

.cards {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
    gap: 20px;
}

.card {
    background: rgba(22, 32, 20, .85);
    border: 1px solid rgba(180, 255, 120, .1);
    border-radius: 16px;
    padding: 20px;
    text-align: center;
    transition: .2s;
}

.card:hover {
    transform: translateY(-5px);
    border-color: rgba(180, 255, 120, .4);
}

.logo {
    width: 84px;
    height: 84px;
    margin-bottom: 10px;
}

.btn {
    display: inline-block;
    margin-top: 10px;
    background: linear-gradient(180deg, #c8f07a, #9ec94e);
    color: #111;
    padding: 10px 16px;
    border-radius: 10px;
    text-decoration: none;
    font-weight: bold;
}

.footer {
    text-align: center;
    color: #777;
    padding: 40px 0;
}
&lt;/style&gt;
&lt;/head&gt;

&lt;body&gt;

&lt;div class="hero-banner"&gt;
    &lt;img src="banner1.png"&gt;
    &lt;div class="hero-overlay"&gt;
