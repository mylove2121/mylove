<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 512 512" role="img" aria-label="RewardPX icon">
  <defs>
    <linearGradient id="bg" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" stop-color="#0a0c12"/>
      <stop offset="100%" stop-color="#151821"/>
    </linearGradient>
    <linearGradient id="neon" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" stop-color="#00ffaa"/>
      <stop offset="100%" stop-color="#00cc88"/>
    </linearGradient>
    <filter id="glow" x="-30%" y="-30%" width="160%" height="160%">
      <feGaussianBlur stdDeviation="14" result="b"/>
      <feMerge>
        <feMergeNode in="b"/>
        <feMergeNode in="SourceGraphic"/>
      </feMerge>
    </filter>
  </defs>

  <!-- Background tile -->
  <rect width="512" height="512" rx="112" fill="url(#bg)"/>

  <!-- Neon border ring -->
  <rect x="20" y="20" width="472" height="472" rx="96" fill="none" stroke="url(#neon)" stroke-width="6" opacity="0.35"/>

  <!-- Subtle dot grid -->
  <g fill="#00ffaa" opacity="0.06">
    <circle cx="80"  cy="80"  r="3"/>
    <circle cx="160" cy="80"  r="3"/>
    <circle cx="80"  cy="160" r="3"/>
    <circle cx="432" cy="80"  r="3"/>
    <circle cx="432" cy="432" r="3"/>
    <circle cx="80"  cy="432" r="3"/>
  </g>

  <!-- Main "R" mark with neon glow -->
  <g filter="url(#glow)">
    <text x="256" y="356"
          font-family="'IBM Plex Mono','SF Mono','Courier New',monospace"
          font-size="320"
          font-weight="800"
          text-anchor="middle"
          fill="url(#neon)"
          letter-spacing="-8">R</text>
  </g>

  <!-- Accent dot (px / pixel reference) -->
  <circle cx="368" cy="368" r="22" fill="#00ffaa"/>
  <circle cx="368" cy="368" r="22" fill="none" stroke="#00ffaa" stroke-width="2" opacity="0.4">
    <animate attributeName="r" values="22;32;22" dur="2.5s" repeatCount="indefinite"/>
    <animate attributeName="opacity" values="0.5;0;0.5" dur="2.5s" repeatCount="indefinite"/>
  </circle>
</svg>
